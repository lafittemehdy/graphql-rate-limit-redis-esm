{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "forceConsistentCasingInFileNames": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2024"
  },
  "exclude": ["dist", "node_modules", "src/__tests__", "src/bench.ts"],
  "include": ["src/**/*"]
}
