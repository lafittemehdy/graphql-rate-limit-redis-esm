{
	"name": "graphql-rate-limit-redis-esm",
	"version": "3.0.1",
	"description": "Production-ready GraphQL rate limiting directive for Redis with ESM support",
	"author": "Lafitte Mehdy (https://github.com/lafittemehdy)",
	"license": "MIT",
	"packageManager": "pnpm@11.1.3",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"engines": {
		"node": ">=22.13.0"
	},
	"keywords": [
		"directive",
		"dos-protection",
		"esm",
		"graphql",
		"graphql-security",
		"rate-limit",
		"redis",
		"security"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/lafittemehdy/graphql-rate-limit-redis-esm.git"
	},
	"bugs": {
		"url": "https://github.com/lafittemehdy/graphql-rate-limit-redis-esm/issues"
	},
	"homepage": "https://github.com/lafittemehdy/graphql-rate-limit-redis-esm#readme",
	"sideEffects": false,
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"peerDependencies": {
		"@graphql-tools/utils": "^10.0.0 || ^11.0.0",
		"graphql": "^16.0.0 || ^17.0.0",
		"rate-limiter-flexible": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0"
	},
	"devDependencies": {
		"@apollo/server": "^5.5.1",
		"@biomejs/biome": "^2.4.16",
		"@graphql-tools/schema": "^10.0.33",
		"@graphql-tools/utils": "^11.1.0",
		"@types/node": "^25.9.2",
		"@vitest/coverage-v8": "^4.1.8",
		"@vitest/ui": "^4.1.8",
		"graphql": "^16.14.1",
		"graphql-yoga": "^5.21.2",
		"husky": "^9.1.7",
		"ioredis": "^5.11.1",
		"rate-limiter-flexible": "^11.2.0",
		"tsup": "^8.5.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"scripts": {
		"benchmark": "tsx src/bench.ts",
		"build": "tsup",
		"check:workflow": "node scripts/check-pnpm-setup.mjs",
		"dev": "tsc --watch",
		"example:apollo": "tsx examples/servers/apollo-server.ts",
		"example:yoga": "tsx examples/servers/yoga-server.ts",
		"lint": "biome check && tsc --noEmit && pnpm run check:workflow",
		"lint:fix": "biome check --write && tsc --noEmit",
		"prepare": "husky",
		"prepublishOnly": "pnpm run lint && pnpm run build && pnpm test",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"test:watch": "vitest"
	}
}
