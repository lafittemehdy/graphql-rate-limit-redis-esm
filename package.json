{
	"name": "graphql-rate-limit-redis-esm",
	"version": "4.0.0",
	"description": "Production-ready GraphQL rate limiting directive for Redis with ESM support",
	"author": "Lafitte Mehdy (https://github.com/lafittemehdy)",
	"license": "MIT",
	"packageManager": "pnpm@11.15.1",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			},
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"engines": {
		"node": ">=22.13.0"
	},
	"keywords": [
		"directive",
		"dos-protection",
		"esm",
		"graphql",
		"graphql-security",
		"rate-limit",
		"redis",
		"security"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lafittemehdy/graphql-rate-limit-redis-esm.git"
	},
	"bugs": {
		"url": "https://github.com/lafittemehdy/graphql-rate-limit-redis-esm/issues"
	},
	"homepage": "https://github.com/lafittemehdy/graphql-rate-limit-redis-esm#readme",
	"sideEffects": false,
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"peerDependencies": {
		"@graphql-tools/utils": "^10.0.0 || ^11.0.0",
		"graphql": "^16.0.0 || ^17.0.0",
		"rate-limiter-flexible": "^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0"
	},
	"devDependencies": {
		"@apollo/server": "^5.5.1",
		"@biomejs/biome": "^2.5.5",
		"@graphql-tools/schema": "^10.0.38",
		"@graphql-tools/utils": "^11.2.2",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"@vitest/ui": "^4.1.10",
		"graphql": "^16.14.2",
		"graphql-yoga": "^5.21.2",
		"husky": "^9.1.7",
		"ioredis": "^5.11.1",
		"rate-limiter-flexible": "^11.2.0",
		"tsup": "^8.5.1",
		"tsx": "^4.23.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	},
	"scripts": {
		"benchmark": "tsx src/bench.ts",
		"build": "tsup",
		"check:consumers": "tsc --noEmit --project tsconfig.consumers.json",
		"check:examples": "tsc --noEmit --project tsconfig.examples.json",
		"check:package": "node scripts/check-package-exports.mjs && npm pack --dry-run --ignore-scripts",
		"check:workflow": "node scripts/check-pnpm-setup.mjs",
		"dev": "tsc --watch",
		"example:apollo": "tsx examples/servers/apollo-server.ts",
		"example:yoga": "tsx examples/servers/yoga-server.ts",
		"lint": "biome check && tsc --noEmit && pnpm run check:examples && pnpm run check:workflow",
		"lint:fix": "biome check --write && tsc --noEmit && pnpm run check:examples",
		"prepare": "husky",
		"prepublishOnly": "pnpm run verify",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"verify": "pnpm run lint && pnpm run build && pnpm run check:consumers && pnpm run test:coverage && pnpm run check:package"
	}
}
