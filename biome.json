{
	"$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
	"assist": {
		"enabled": true
	},
	"files": {
		"includes": ["**", "!coverage", "!dist"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineEnding": "auto",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	}
}
